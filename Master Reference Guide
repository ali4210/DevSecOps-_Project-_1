### Step 7: Configure Jenkins Pipeline

**Required Plugins:**
1. Go to Manage Jenkins → Manage Plugins → Available
2. Install:
   - SonarQube Scanner
   - Email Extension Plugin
   - Pipeline
   - Git
   - HTML Publisher

**Create New Pipeline Job:**
1. New Item → Pipeline → Name: `DevSecOps-Pipeline`
2. Configure → Pipeline → Pipeline script:

```groovy
pipeline {
    agent any
    
    environment {
        HOST_PATH = '/root/DevSecOps/sample-app'  // Update this path
        APP_PORT = '8082'
        SONAR_TOKEN = credentials('sonarqube-token')
        EMAIL_RECIPIENT = 'your-email@gmail.com'  // Update this
    }
    
    triggers {
        pollSCM('* * * * *')  // Poll every minute
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out source code...'
                // Add your Git checkout here if using version control
                sh 'echo "Code checked out successfully"'
            }
        }
        
        stage('Build') {
            steps {
                echo 'Building application...'
                dir("${HOST_PATH}") {
                    sh 'npm install'
                }
            }
        }
        
        stage('SAST - SonarQube') {
            steps {
                echo 'Running Static Application Security Testing...'
                script {
                    def scannerHome = tool 'SonarScanner'
                    withSonarQubeEnv('SonarQube-Server') {
                        sh """
                            cd ${HOST_PATH}
                            ${scannerHome}/bin/sonar-scanner
                        """
                    }
                }
            }
        }
        
        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
        
        stage('Deploy to Production') {
            steps {
                echo 'Deploying to production...'
                sh """
                    docker stop production-app || true
                    docker rm production-app || true
                    
                    docker run -d \\
                      --name production-app \\
                      -p ${APP_PORT}:3000 \\
                      -v ${HOST_PATH}:/app \\
                      -w /app \\
                      node:16 \\
                      npm start
                """
            }
        }
        
        stage('DAST - ZAP Scan') {
            steps {
                echo 'Running Dynamic Application Security Testing...'
                sh """
                    mkdir -p ${WORKSPACE}/zap-reports
                    
                    docker run --rm \\
                      -v ${WORKSPACE}/zap-reports:/zap/wrk/:rw \\
                      -t owasp/zap2docker-stable zap-baseline.py \\
                      -t http://host.docker.internal:${APP_PORT} \\
                      -J report.json \\
                      -r report.html || true
                """
            }
        }
    }
    
    post {
        always {
            archiveArtifacts artifacts: 'zap-reports/*', allowEmptyArchive: true
        }
        success {
            emailext (
                to: "${EMAIL_RECIPIENT}",
                subject: "✅ Pipeline SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: "Build completed successfully. View: ${env.BUILD_URL}",
                mimeType: 'text/plain'
            )
        }
        failure {
            emailext (
                to: "${EMAIL_RECIPIENT}",
                subject: "❌ Pipeline FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: "Build failed. Check logs: ${env.BUILD_URL}console",
                mimeType: 'text/plain'
            )
        }
    }
}
```

